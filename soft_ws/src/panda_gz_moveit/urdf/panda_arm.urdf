        <mesh filename="file:///workspace/install/panda_gz_moveit/share/panda_gz_moveit/meshes/collision/finger.obj" />
      </geometry>
      <material name="panda_white" />
    </collision>
  </link>

  <link name="panda_rightfinger">
    <inertial><mass value="0.05" /><origin xyz="0 0 0" rpy="0 0 0" /><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01" /></inertial>
    <visual>
      <origin rpy="0 0 3.14159265359" xyz="0 0 0" />
      <geometry>
        <mesh filename="file:///workspace/install/panda_gz_moveit/share/panda_gz_moveit/meshes/collision/finger.obj" />
      </geometry>
