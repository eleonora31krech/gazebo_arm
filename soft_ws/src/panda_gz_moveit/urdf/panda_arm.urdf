    <collision>
      <geometry>
        <mesh filename="file:///workspace/install/panda_gz_moveit/share/panda_gz_moveit/meshes/collision/link1.obj" />
      </geometry>
      <material name="panda_white" />
    </collision>
  </link>

  <joint name="panda_joint1" type="revolute">
    <safety_controller k_position="100.0" k_velocity="40.0" soft_lower_limit="-2.8973" soft_upper_limit="2.8973" />
    <origin rpy="0 0 0" xyz="0 0 0.333" />
    <parent link="panda_link0" />
    <child link="panda_link1" />
    <axis xyz="0 0 1" />
    <limit effort="87" lower="-2.9671" upper="2.9671" velocity="2.1750" />
    <dynamics damping="10.0" friction="1.0"/>
  </joint>

  <link name="panda_link2">
    <inertial><mass value="4.0" /><origin xyz="0 0 0" rpy="0 0 0" /><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01" /></inertial>
