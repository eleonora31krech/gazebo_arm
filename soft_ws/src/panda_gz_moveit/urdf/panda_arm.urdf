<?xml version='1.0' encoding='utf-8'?>
<robot name="panda">
<link name="world"/>

<joint name="world_to_panda" type="fixed">
  <parent link="world"/>
  <child link="panda_link0"/>
  <origin xyz="0 0 0" rpy="0 0 0"/>
</joint>

  <link name="panda_link0">
    <inertial>
      <mass value="100.0" />
      <origin xyz="0 0 -0.05" rpy="0 0 0" />
      <inertia ixx="1.0" ixy="0" ixz="0" iyy="1.0" iyz="0" izz="1.0" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="file:///workspace/install/panda_gz_moveit/share/panda_gz_moveit/meshes/collision/link0.obj" />
      </geometry>
      <material name="panda_white" />
    </visual>
    <collision>
      <geometry>
        <mesh filename="file:///workspace/install/panda_gz_moveit/share/panda_gz_moveit/meshes/collision/link0.obj" />
      </geometry>
      <material name="panda_white" />
      <surface>
        <friction>
          <ode>
            <mu>100.0</mu>
            <mu2>100.0</mu2>
          </ode>
        </friction>
      </surface>
    </collision>
  </link>

  <link name="panda_link1">
    <inertial><mass value="4.0" /><origin xyz="0 0 0" rpy="0 0 0" /><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01" /></inertial>
    <visual>
